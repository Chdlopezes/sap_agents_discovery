# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
venv/
.venv/
env/
ENV/

# ─────────────────────────────────────────────────────────────────────────────
# Secretos / variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
.envrc
*.secret
*.key
*.pem

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code (estado por-usuario, NO se comparte)
# ─────────────────────────────────────────────────────────────────────────────
.claude/

# ─────────────────────────────────────────────────────────────────────────────
# Editores / IDEs
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Playwright (browsers descargados, reportes, caches locales)
# ─────────────────────────────────────────────────────────────────────────────
playwright-report/
playwright/.cache/
.cache/ms-playwright/
test-results/

# ─────────────────────────────────────────────────────────────────────────────
# Excel lock files (Office crea ~$nombre.xlsx al abrir)
# ─────────────────────────────────────────────────────────────────────────────
~$*.xlsx
~$*.xls
~$*.docx
~$*.doc

# ─────────────────────────────────────────────────────────────────────────────
# Logs y temporales
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.tmp
tmp/
.tmp/

# ─────────────────────────────────────────────────────────────────────────────
# Notebooks
# ─────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────────────────────
# Archivos de trabajo temporales del pipeline
# (CSVs / scratch files que el agente cree mientras opera, no relevantes
# para reproducir desde otro computador)
# ─────────────────────────────────────────────────────────────────────────────
inputs/missing_*.csv
inputs/_scratch_*.csv
*.scratch.md
*.bak
